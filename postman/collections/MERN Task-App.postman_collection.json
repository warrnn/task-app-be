            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation CreateTask($title: String!, $description: String, $startedAt: String, $endAt: String) {\r\n    createTask(\r\n        title: $title\r\n        description: $description\r\n        startedAt: $startedAt\r\n        endAt: $endAt\r\n    ) {\r\n        message\r\n        task {\r\n            id\r\n            title\r\n            description\r\n            isDone\r\n            userId\r\n            startedAt\r\n            endAt\r\n            createdAt\r\n            updatedAt\r\n        }\r\n    }\r\n}",
                "variables": "{\r\n    \"title\": \"Make Salad\",\r\n    \"description\": \"Make egg salad with air fryed wheat bread\",\r\n    \"startedAt\": \"2026-07-01T16:00:00.000+07:00\",\r\n    \"endAt\": \"2026-07-01T16:30:00.000+07:00\"\r\n}"
              }
